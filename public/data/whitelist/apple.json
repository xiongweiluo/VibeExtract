          }
        ]
      },
      {
        "id": "promo-banner",
        "semanticType": "banner",
        "layoutClasses": "w-full flex items-center justify-center px-[24px] py-[8px] bg-[var(--color-bg-surface)] border-b border-[var(--color-border-default)]",
        "zLayer": "base",
        "components": [
          {
            "role": "promo-text",
            "classes": "text-[12px] font-[400] leading-[1.3] tracking-[-0.12px] text-[var(--color-text-secondary)] text-center",
            "content": "Recycle an eligible device in a store and get 10% off an Apple accessory.¹"
          },
          {
            "role": "promo-link",
            "classes": "ml-[4px] text-[12px] font-[400] leading-[1.3] tracking-[-0.12px] text-[var(--color-brand-primary)] underline-offset-2 cursor-pointer",
            "content": "Find a store ›"
          }
        ]
      },
      {
        "id": "hero-iphone",
        "semanticType": "hero",
        "layoutClasses": "w-full flex flex-col items-center pt-[88px] pb-[44px] bg-[var(--color-bg-page)]",
        "zLayer": "base",
        "components": [
          {
            "role": "hero-eyebrow",
            "classes": "text-[34px] font-[600] leading-[1.5] tracking-[-0.374px] text-[var(--color-text-primary)] font-['SF_Pro_Display',_sans-serif] text-center",
            "content": "iPhone"
          },
          {
            "role": "hero-subheading",
            "classes": "mt-[8px] text-[24px] font-[600] leading-[1.2] tracking-[0.216px] text-[var(--color-text-primary)] font-['SF_Pro_Display',_sans-serif] text-center",
            "content": "Meet the latest iPhone lineup."
          },
          {
            "role": "cta-group",
            "classes": "mt-[24px] flex items-center gap-[16px]",
            "children": [
              {
                "role": "cta-primary",
                "classes": "px-[20px] py-[8px] rounded-[9999px] bg-[var(--color-brand-primary)] text-[var(--color-text-inverse)] text-[17px] font-[400] leading-[1.5] tracking-[-0.374px] cursor-pointer",
                "content": "Learn more"
              },
              {
                "role": "cta-secondary",
                "classes": "px-[20px] py-[8px] rounded-[9999px] border border-[var(--color-brand-primary)] text-[var(--color-brand-primary)] text-[17px] font-[400] leading-[1.5] tracking-[-0.374px] bg-transparent cursor-pointer",
                "content": "Shop iPhone"
              }
            ]
          },
          {
            "role": "hero-product-image",
            "classes": "mt-[44px] w-full max-w-[640px] h-auto object-contain"
          }
        ]
      },
      {
        "id": "hero-macbook-neo",
        "semanticType": "hero",
        "layoutClasses": "w-full flex flex-col items-center pt-[84px] pb-[0px] bg-[var(--color-bg-page)]",
        "zLayer": "base",
