  "uiBlueprint": {
    "sections": [
      {
        "id": "nav",
        "semanticType": "nav",
        "layoutClasses": "flex items-center justify-between w-full px-[16px] h-[40px] bg-[var(--color-bg-page)] border-b border-[var(--color-border-default)]",
        "zLayer": "floating",
        "components": [
          {
            "role": "nav-links",
            "classes": "flex items-center gap-[16px] text-[13px] font-[400] text-[var(--color-text-primary)] font-['Arial','PingFang_SC',sans-serif]",
            "repeats": 9,
            "children": [
              {
                "role": "nav-item",
                "classes": "cursor-pointer hover:text-[var(--color-brand-primary)]",
                "content": "新闻"
              }
            ]
          },
          {
            "role": "nav-actions",
            "classes": "flex items-center gap-[16px]",
            "children": [
              {
                "role": "nav-setting",
                "classes": "text-[13px] font-[400] text-[var(--color-text-primary)] cursor-pointer",
                "content": "设置"
              },
              {
                "role": "cta-button",
                "classes": "px-[16px] py-[4px] rounded-[full] bg-[var(--color-brand-primary)] text-[var(--color-text-inverse)] text-[13px] font-[400] font-['Arial','PingFang_SC',sans-serif]",
                "content": "登录"
              }
            ]
          }
        ]
      },
      {
        "id": "hero",
        "semanticType": "hero",
        "layoutClasses": "flex flex-col items-center justify-center w-full pt-[120px] pb-[32px] bg-[var(--color-bg-page)]",
        "zLayer": "base",
        "components": [
          {
            "role": "brand-logo",
            "classes": "h-[120px] w-auto mb-[32px]"
          },
          {
            "role": "search-bar",
            "classes": "relative flex items-center w-[644px] h-[52px] rounded-[full] border border-[var(--color-border-default)] bg-[var(--color-bg-page)] shadow-[rgba(0,0,0,0.1)_0px_1px_10px_0px]",
            "children": [
              {
                "role": "search-input",
                "classes": "flex-1 h-full px-[16px] text-[16px] font-[400] text-[var(--color-text-primary)] font-['Arial','PingFang_SC',sans-serif] bg-transparent outline-none",
                "content": "张凌赫登上法国第一大报纸"
              },
              {
                "role": "search-input-icons",
                "classes": "flex items-center gap-[8px] px-[8px]",
                "children": [
                  {
                    "role": "icon-mic",
                    "classes": "w-[20px] h-[20px] text-[var(--color-text-secondary)] cursor-pointer"
                  },
                  {
                    "role": "icon-attach",
                    "classes": "w-[20px] h-[20px] text-[var(--color-text-secondary)] cursor-pointer"
                  },
                  {
                    "role": "icon-camera",
                    "classes": "w-[20px] h-[20px] text-[var(--color-text-secondary)] cursor-pointer"
                  }
                ]
              },
              {
                "role": "search-submit-button",
                "classes": "h-full px-[32px] rounded-r-[full] bg-[var(--color-brand-primary)] text-[var(--color-text-inverse)] text-[18px] font-[400] font-['Arial','PingFang_SC',sans-serif] cursor-pointer shrink-0",
                "content": "百度一下"
              }
            ]
          }
        ]
      },
      {
        "id": "ai-promo-banner",
        "semanticType": "banner",
        "layoutClasses": "flex items-center justify-center w-full py-[24px] bg-[var(--color-bg-page)]",
        "zLayer": "base",
        "components": [
          {
            "role": "promo-pill",
            "classes": "flex items-center gap-[8px] px-[16px] py-[8px] rounded-[full] bg-[var(--color-bg-surface)] text-[13px] font-[400] text-[var(--color-text-primary)] font-['Arial','PingFang_SC',sans-serif] cursor-pointer",
            "children": [
              {
                "role": "promo-icon",
                "classes": "w-[16px] h-[16px] shrink-0"
              },
              {
                "role": "promo-text",
                "classes": "text-[13px] text-[var(--color-text-primary)]",
                "content": "复杂问题就找文心助手，深入思考回答更优"
              },
              {
                "role": "promo-chevron",
                "classes": "w-[12px] h-[12px] text-[var(--color-text-secondary)]"
              }
            ]
          }
        ]
      },
      {
        "id": "hot-search",
        "semanticType": "content",
        "layoutClasses": "w-[780px] mx-auto pt-[32px] pb-[48px] bg-[var(--color-bg-page)]",
        "zLayer": "base",
        "components": [
          {
            "role": "section-header",
            "classes": "flex items-center justify-between mb-[24px]",
            "children": [
              {
                "role": "section-title",
                "classes": "flex items-center gap-[8px] text-[16px] font-[400] text-[var(--color-text-primary)] font-['Arial','PingFang_SC',sans-serif]",
                "content": "百度热搜"
              },
              {
                "role": "refresh-btn",
                "classes": "flex items-center gap-[4px] text-[13px] text-[var(--color-text-secondary)] cursor-pointer",
                "content": "换一换"
              }
            ]
          },
          {
            "role": "hot-search-grid",
            "classes": "grid grid-cols-2 gap-x-[40px] gap-y-[24px]",
            "repeats": 9,
            "children": [
              {
                "role": "hot-search-item",
                "classes": "flex items-center gap-[12px] cursor-pointer",
                "children": [
                  {
                    "role": "rank-number",
                    "classes": "w-[16px] text-[13px] font-[400] text-[var(--color-text-secondary)] font-['Arial','PingFang_SC',sans-serif] shrink-0"
                  },
                  {
                    "role": "item-title",
                    "classes": "text-[13px] font-[400] text-[var(--color-text-primary)] font-['Arial','PingFang_SC',sans-serif] flex-1",
                    "content": "习近平会见沙伦赛"
                  },
                  {
                    "role": "item-badge",
                    "classes": "text-[12px] font-[400] text-[var(--color-text-inverse)] bg-[var(--color-status-warning)] px-[4px] py-[2px] rounded-[sm]",
                    "content": "热"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "id": "floating-side-tools",
        "semanticType": "aside",
        "layoutClasses": "fixed right-[8px] bottom-[120px] flex flex-col gap-[8px] z-[100]",
        "zLayer": "floating",
        "components": [
          {
            "role": "side-tool-icon",
            "classes": "w-[40px] h-[40px] rounded-[full] bg-[var(--color-bg-surface)] shadow-[rgba(0,0,0,0.1)_0px_1px_10px_0px] flex items-center justify-center cursor-pointer"
          },
          {
            "role": "side-tool-icon",
            "classes": "w-[40px] h-[40px] rounded-[full] bg-[var(--color-bg-surface)] shadow-[rgba(0,0,0,0.1)_0px_1px_10px_0px] flex items-center justify-center cursor-pointer"
          }
        ]
      },
      {
        "id": "footer",
        "semanticType": "footer",
        "layoutClasses": "flex items-center justify-center flex-wrap gap-[16px] w-full py-[16px] px-[16px] bg-[var(--color-bg-page)] border-t border-[var(--color-bg-surface)]",
        "zLayer": "base",
        "components": [
          {
            "role": "footer-links",
            "classes": "flex items-center flex-wrap gap-[16px] text-[12px] font-[400] text-[var(--color-text-secondary)] font-['Arial','PingFang_SC',sans-serif]",
            "repeats": 10,
            "children": [
              {
                "role": "footer-link",
                "classes": "cursor-pointer hover:text-[var(--color-brand-primary)]",
                "content": "关于百度"
              }
            ]
          }
        ]
      }
    ]
